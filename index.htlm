<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SignalGen | Your Network, Your Channels</title>
  <link rel="stylesheet" href="styles.css" />
</head>
<body>

  <!-- HEADER -->
  <header class="site-header">
    <div class="container header-wrap">
      <div class="logo">SignalGen</div>
      <nav class="main-nav">
        <a href="#channels">Channels</a>
        <a href="#how-it-works">How It Works</a>
        <a href="#dashboard-preview">Dashboard</a>
        <a href="#featured">Featured</a>
      </nav>
      <div class="header-actions">
        <a href="#" class="btn btn-outline">Sign In</a>
        <a href="#" class="btn btn-solid">Create Free Profile</a>
      </div>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="container hero-content">
      <p class="eyebrow">ONE NETWORK • ONE FREE PROFILE • CUSTOM CHANNELS</p>
      <h1>Your personalized control center for the channels you choose.</h1>
      <p class="hero-text">
        SignalGen lets users create one free profile, select their favorite channels,
        and build a custom stream of signals across the network.
      </p>
      <div class="hero-buttons">
        <a href="#channels" class="btn btn-solid">Pick My Channels</a>
        <a href="#how-it-works" class="btn btn-outline">See How It Works</a>
      </div>
    </div>
  </section>

  <!-- CHANNEL SELECTOR -->
  <section id="channels" class="section">
    <div class="container">
      <h2>Choose Your Channels</h2>
      <p class="section-intro">
        Start with the topics that matter most to you. Build your own signal mix.
      </p>

      <div class="channel-grid">
        <div class="channel-card">RheoGen</div>
        <div class="channel-card">JobsGen</div>
        <div class="channel-card">TravelGen</div>
        <div class="channel-card">CarsGen</div>
        <div class="channel-card">ScienceGen</div>
        <div class="channel-card">MoviesGen</div>
        <div class="channel-card">KpopGen</div>
        <div class="channel-card">PollingGen</div>
        <div class="channel-card">FakeNewsGen</div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" class="section alt-section">
    <div class="container">
      <h2>How It Works</h2>
      <div class="three-col">
        <div class="info-card">
          <h3>1. Create One Free Profile</h3>
          <p>
            Sign up once and use the same profile across the full SignalGen network.
          </p>
        </div>
        <div class="info-card">
          <h3>2. Choose Your Channels</h3>
          <p>
            Select the channels that match your interests, goals, and daily priorities.
          </p>
        </div>
        <div class="info-card">
          <h3>3. Receive Custom Signals</h3>
          <p>
            Get a personalized feed of updates, trends, tools, and opportunities.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- DASHBOARD PREVIEW -->
  <section id="dashboard-preview" class="section">
    <div class="container">
      <h2>Dashboard Preview</h2>
      <p class="section-intro">
        A first look at how your signal feed could be organized.
      </p>

      <div class="dashboard-preview-box">
        <div class="dashboard-column">
          <h3>My Channels</h3>
          <ul>
            <li>RheoGen</li>
            <li>JobsGen</li>
            <li>ScienceGen</li>
            <li>FakeNewsGen</li>
          </ul>
        </div>

        <div class="dashboard-column">
          <h3>Today’s Signals</h3>
          <ul>
            <li>Affordability trend update</li>
            <li>New job market shift</li>
            <li>Science headline gaining traction</li>
            <li>Verified news story rating changed</li>
          </ul>
        </div>

        <div class="dashboard-column">
          <h3>Recommended Next</h3>
          <ul>
            <li>Add TravelGen</li>
            <li>Follow PollingGen</li>
            <li>Save your dashboard preferences</li>
            <li>Turn on future alerts</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED CHANNELS -->
  <section id="featured" class="section alt-section">
    <div class="container">
      <h2>Featured Channels</h2>
      <div class="featured-grid">
        <div class="featured-card">
          <h3>RheoGen</h3>
          <p>Signals around affordability, daily pressure, and economic reality.</p>
        </div>
        <div class="featured-card">
          <h3>JobsGen</h3>
          <p>Work, side-income, hiring shifts, and career movement.</p>
        </div>
        <div class="featured-card">
          <h3>TravelGen</h3>
          <p>Travel planning, movement, and destination opportunities.</p>
        </div>
        <div class="featured-card">
          <h3>CarsGen</h3>
          <p>Mobility signals, buying decisions, and ownership trends.</p>
        </div>
        <div class="featured-card">
          <h3>ScienceGen</h3>
          <p>Future-facing science, discovery, and public-interest innovation.</p>
        </div>
        <div class="featured-card">
          <h3>FakeNewsGen</h3>
          <p>Vets major verified trending news reports on a polygraph-style scale.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="container">
      <p>© 2026 SignalGen.xyz — One network. One profile. Custom channels.</p>
    </div>
  </footer>

</body>
</html>
